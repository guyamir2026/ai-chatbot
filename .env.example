# ─── Telegram Bot ───────────────────────────────────────────────────────────
# Get this from BotFather on Telegram
TELEGRAM_BOT_TOKEN=""

# Get your personal chat ID from a bot like @userinfobot
# This is where you will receive notifications for agent requests and appointments
TELEGRAM_OWNER_CHAT_ID=""

# ─── Webhook Mode (optional) ─────────────────────────────────────────────────
# To switch from polling to webhook mode, set WEBHOOK_URL to your public HTTPS URL.
# When set, the bot receives updates via the Flask server instead of polling.
# WEBHOOK_URL="https://your-domain.com/telegram/webhook"
# WEBHOOK_SECRET="random-secret-string-for-verification"

# ─── OpenAI / LLM ───────────────────────────────────────────────────────────
# Your OpenAI API key is automatically configured in the environment.
# ברירת מחדל: OpenAI (gpt-4.1-mini + text-embedding-3-small)
# OPENAI_MODEL="gpt-4.1-mini"
# EMBEDDING_MODEL="text-embedding-3-small"
#
# לשימוש ב-Gemini — להגדיר base URL ולשנות מודלים:
# OPENAI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# OPENAI_API_KEY="your-google-api-key"
# OPENAI_MODEL="gemini-2.5-flash"
# EMBEDDING_MODEL="gemini-embedding-001"

# Maximum tokens for LLM response (default: 2048)
# LLM_MAX_TOKENS=2048

# ─── LLM Intent Detection ──────────────────────────────────────────────────
# זיהוי כוונות מבוסס LLM — תופס ניסוחים טבעיים שה-regex מפספס.
# מודל קל (nano) לסיווג מהיר וזול. ניתן לכבות עם false.
# LLM_INTENT_ENABLED=true
# INTENT_MODEL="gpt-4.1-nano"

# ─── Web Admin Panel ─────────────────────────────────────────────────────────
# Credentials for the web admin login
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme123"

# Secret key for Flask session management (change to a random string)
ADMIN_SECRET_KEY="super-secret-key-change-me"

# Secrets encryption key — מצפין שדות סודיים ב-DB (refresh_token של Google
# Calendar וכד'). חייב להיות נפרד מ-ADMIN_SECRET_KEY ומ-DB_PATH כדי שגם
# אם DB דולף, התוקף לא יוכל לפענח. לייצור מפתח תקין:
#   python -c 'from utils.crypto import generate_new_key; print(generate_new_key())'
# אם לא מוגדר — שדות מוצפנים נשמרים בטקסט גלוי (legacy mode), עם אזהרה ב-log.
# SECRETS_ENCRYPTION_KEY=""

# Pepper לפנקס הסכמות פסאודונימי (consent_ledger). חייב להיות נפרד מ-
# SECRETS_ENCRYPTION_KEY ומ-ADMIN_SECRET_KEY כדי שדליפה של אחד לא תפגע
# באחרים. בלעדיו, רשומות ledger לא ייכתבו (logger.error, לא חוסם).
# לייצור: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# במקרה של דליפה: ייצרו LEDGER_PEPPER_V2, עדכנו CURRENT_PEPPER_VERSION
# ב-utils/consent_ledger.py, וקראו ל-mark_pepper_compromised('v1').
# LEDGER_PEPPER_V1=""

# Network settings for the admin panel
# ADMIN_HOST="0.0.0.0"
# ADMIN_PORT=5000

# Public URL of the admin panel — used for links in Telegram notifications to business owner
# ADMIN_URL="https://my-bot-admin.onrender.com"

# ─── Conversation Memory ────────────────────────────────────────────────────
# Number of recent full messages to include in each LLM call
# CONTEXT_WINDOW_SIZE=10

# Number of messages between automatic conversation summaries
# SUMMARY_THRESHOLD=10

# ─── Follow-up Questions (Premium Feature) ──────────────────────────────────
# Enable smart follow-up question suggestions after each bot response
# Suggests 2-3 relevant questions as inline buttons to increase engagement
# FOLLOW_UP_ENABLED=false

# ─── Business Info (legacy fallback) ────────────────────────────────────────
# Multi-tenant: the business NAME comes from the tenant's display_name (set at
# onboarding, single source of truth). Phone/address/website are edited in the
# admin panel ("כרטיס ביקור" / Business Card) and stored per-tenant in the DB.
# These env vars are read ONLY for the default/legacy tenant (or when a DB
# field is empty).
BUSINESS_NAME="Dana's Beauty Salon"

# Business contact details — used for the vCard (digital business card) feature
# BUSINESS_PHONE="03-555-0123"
# BUSINESS_ADDRESS="שדרות רוטשילד 123, תל אביב-יפו"
# BUSINESS_WEBSITE="https://www.danasbeauty.co.il"

# Bot username (without @) — used for QR code generation and referral links.
# Legacy fallback: platform tenants capture it automatically (getMe) when the
# Telegram token is connected in the infra-settings screen.
# TELEGRAM_BOT_USERNAME="DanasBeautyBot"

# ─── Google Calendar Sync ────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Required scopes: https://www.googleapis.com/auth/calendar
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI="https://your-domain.com/google/callback"

# ─── WhatsApp / Twilio ──────────────────────────────────────────────────────
# Twilio credentials for WhatsApp Business integration.
# Get these from https://console.twilio.com
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_NUMBER="+14155551234"
# מספר WhatsApp של בעל העסק — לקבלת התראות על תורים ובקשות נציג
# פורמט E.164: +972XXXXXXXXX (עם + וללא 0 מוביל)
# OWNER_WHATSAPP_NUMBER="+972501234567"

# ─── Meta (Instagram + Facebook Messenger DM) ───────────────────────────────
# פרטי האפליקציה ב-Meta for Developers. ראה docs/meta_dm_spec.md.
# Webhook URL להגדרה אצל מטא: https://<your-domain>/webhooks/meta
# META_APP_ID=""
# META_APP_SECRET=""
# Token חופשי שאתה בוחר; מטא תשלח אותו ב-handshake של ה-webhook
# META_VERIFY_TOKEN="choose-a-long-random-string"
# META_GRAPH_API_VERSION="v21.0"
# OAuth redirect — חייב להתאים בדיוק למה שמוגדר ב-Meta App Dashboard
# META_OAUTH_REDIRECT_URI="https://your-domain.com/admin/meta/callback"
# מגבלות אורך הודעה (תווים). מעבר אליהן — שליחה כעמוד HTML ציבורי.
# META_MESSENGER_MAX_LENGTH="2000"
# META_INSTAGRAM_MAX_LENGTH="1000"
# הצפנת page access tokens — משתמש ב-SECRETS_ENCRYPTION_KEY הקיים
# (אותו מפתח שמצפין refresh_token של Google Calendar).

# ─── Lead Follow-up (מעקב לידים) ────────────────────────────────────────────
# מערכת אוטומטית שמזהה לידים שלא קבעו תור ושולחת follow-up עדין אחרי 24 שעות.
# FOLLOWUP_ENABLED=false
# מודל LLM למנוע ההחלטה (ברירת מחדל: gemini-3.0-flash — זול ומהיר)
# FOLLOWUP_MODEL="gemini-3.0-flash"
# אם ה-LLM של Follow-up רץ על ספק אחר מהראשי — הגדירו base URL נפרד:
# FOLLOWUP_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
# שעות המתנה לפני שליחת follow-up (ברירת מחדל: 24)
# FOLLOWUP_DELAY_HOURS=24
# סף ביטחון מינימלי 0-100 (מתחתיו לא שולחים אוטומטית)
# FOLLOWUP_MIN_CONFIDENCE=60
# תדירות בדיקת לידים זכאיים (בדקות)
# FOLLOWUP_CHECK_INTERVAL_MINUTES=15

# ─── Web Push Notifications (VAPID) ───────────────────────────────────────────
# התראות מערכת הפעלה לבעל העסק כשלשונית הדשבורד סגורה — בעיקר עבור הודעות
# חדשות בשיחה חיה. המנגנון מבוסס Web Push (תקן RFC 8030) + Service Worker.
# יצירת זוג מפתחות חד-פעמית:
#   python -m utils.vapid_keygen
# הסקריפט מדפיס שתי שורות (VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY) — להעתיק לכאן.
# subject חייב להיות mailto:... עם כתובת אימייל פעילה (push services דורשים את זה).
# בלי שלושת הערכים — התראות Web Push יושבתו בשקט, שאר הפאנל עובד רגיל.
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:owner@example.com"

# ─── Developer Notifications ──────────────────────────────────────────────────
# בוט טלגרם נפרד של המפתח — לקבלת דיווחי באגים מבעלי עסקים דרך הפאנל.
# יוצרים בוט אחד ב-BotFather ומשתמשים בו בכל ה-deployments.
# DEVELOPER_BOT_TOKEN=""
# DEVELOPER_CHAT_ID=""
#
# מייל כגיבוי/ערוץ נוסף — אם שניהם מוגדרים, נשלח לשניהם.
# ב-Gmail: יוצרים App Password ב-https://myaccount.google.com/apppasswords
# DEVELOPER_EMAIL="dev@example.com"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_USER=""  # אם ריק — משתמש ב-DEVELOPER_EMAIL
# SMTP_PASSWORD=""

# ─── Error Tracking (Sentry) ──────────────────────────────────────────────────
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"

# ─── Demo Mode (לקמפיין שיווקי) ──────────────────────────────────────────────
# כשמופעל, ה-route /demo פתוח לכניסה בלי הרשמה, יוצר session מבודדת ש-
# *כל* פעולת כתיבה ממנה (POST/PUT/PATCH/DELETE) נחסמת ומחזירה toast.
# ראה docs/demo-mode-spec.md לפרטים.
# DEMO_MODE=true
#
# מספר WhatsApp לרכישה — מופיע בבאנר ובכפתור הצף. בלעדיו ה-CTA מוסתר.
# DEMO_CTA_WHATSAPP="+972501234567"
#
# קישור פתיחה לבוט הטלגרם החי שיוצג לגולשי דמו ב-dashboard.
# DEMO_LIVE_BOT_URL="https://t.me/YourBotUsername?start=demo"
#
# מומלץ להחמיר את ה-rate limit בדמו כדי לא לבזבז קוויקה של OpenAI:
# RATE_LIMIT_PER_DAY=30

# ─── Embed Widget (להטמעת בוט באתר חיצוני) ──────────────────────────────────
# רשימת origins (פסיקים, עם https://, בלי trailing slash) שמורשים לקרוא ל-/widget/api/chat.
# ריק = פתוח לכולם — מומלץ להגדיר את הדומיין של האתר השיווקי כדי למנוע ניצול מ-OpenAI quota.
# WIDGET_ALLOWED_ORIGINS="https://example.com,https://www.example.com"
#
# תקרת הודעות פר-IP בחלון של שעה (קו הגנה אחרון). ברירת מחדל 30.
# WIDGET_RATE_LIMIT_PER_HOUR=30
